				; 3: ora  4:and  5:eor
	define	1,sgn
	define	1,y0back
	define	2,m3l
m3h	equ	m3l+1
	define	9,r0
r1		equ	r0+1
r2		equ	r1+1
r3		equ	r2+1
r4		equ	r3+1
r5		equ	r4+1
r6		equ	r5+1
r7		equ	r6+1
r8		equ	r7+1

	define	1,list_x0	;for list_menu keep right frame coordinate
	define	1,list_y0
