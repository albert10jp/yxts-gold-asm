baishi:
	ldx	man_pai
	cpx	#XIAOYAO_PAI
	beq	not_baishi
	ldx	#0
search_loop:
	cmp	bashi_npc_tbl,x
	beq	find_it
	inx
	cpx	#BAISHI_NPC_NUM
	bcc	search_loop
	lm2	a9,#npc_suit_msg
	jmp	fail_rts
not_baishi:	
	lm2	a9,#have_kf_msg
	jmp	fail_rts

find_it:
	txa
	asl	a
	tax
	lda	baishi_tbl,x
	sta	a1
	inx	
	lda	baishi_tbl,x
	sta	a1h
	jmp	(a1)

	rts		;in case

