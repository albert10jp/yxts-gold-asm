m1l	equ	a1	;(Ë«×Ö˝Ú)
m1h	equ	m1l+1
m2l	equ	a2	;(Ë«×Ö˝Ú)
m2h	equ	m2l+1
__base	equ	graph_buf			;30 bytes
	define	1,x0
	define	1,y0
	define  1,x1
	define  1,y1
	define	1,xx
