get_lvl:
        sta     kf_id
        jsr 	find_kf
        iny
        lda     man_kf,y
        rts

;----------------------
; input:  a9
; output: string_ptr
;----------------------
move_to_img:
	ldy	#0
move_img_loop:
	lda	(a9),y
	sta	img_buf,y
	iny
	cpy	#200
	bcc	move_img_loop
	iny
	lm2	string_ptr,#img_buf
	rts
;----------------------


fail_rts:
	jsr	move_to_img
	sec
	rts
suc_rts:
	jsr	move_to_img
	clc
	rts

