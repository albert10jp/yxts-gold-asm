sub1	macro	s1,s2,d
	sec
	lda	s1
	sbc	s2
	ifidn	<d>,<a>
		sta	s1
	else
		sta	d
	endif
	endm

sub21	macro	s1,s2,d
	sec
	lda	s1
	sbc	s2
	ifidn	<d>,<a>
		sta	s1
		ifzp	s1
			bcs	$+4
		else
			bcs	$+5
		endif
		dec	s1+1
	else
		sta	d
		lda	s1+1
		sta	d+1
		ifzp	d
			bcs	$+4
		else
			bcs	$+5
		endif
		dec	d+1
	endif
	endm

sub42	macro	s1,s2,d,local
	ifidn	<d>,<a>
	else
		lda	s1+2
		sta	d+2
		lda	s1+3
		sta	d+3
	endif

	sec
	lda	s1
	sbc	s2
	ifidn	<d>,<a>
		sta	s1
	else
		sta	d
	endif
