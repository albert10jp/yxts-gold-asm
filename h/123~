PushMenu	macro	layer
	tsx
	txa
	ifidn	<layer>,<a>
		ldx	#0
	else
		ldx	#layer
	endif
	sta	menu_stack,x
	endm

PullMenu	macro	layer
	ifidn	<layer>,<a>
		ldx	#0
	else
		ldx	#layer
	endif
	lda	menu_stack,x
	tax
	txs
	endm

